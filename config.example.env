# Copy this file to config.env and edit values for each project/sample.
# Paths may be absolute or relative to the directory where the pipeline is run.

PROJECT_DIR="/path/to/bacterial_project"
SAMPLE_ID="example_sample"

# Paired-end raw FASTQ inputs. These files must be inside PROJECT_DIR/01_Raw_FASTQ.
R1="${PROJECT_DIR}/01_Raw_FASTQ/example_sample_R1.fastq.gz"
R2="${PROJECT_DIR}/01_Raw_FASTQ/example_sample_R2.fastq.gz"

# Organism metadata passed to Prokka.
GENUS="Escherichia"
SPECIES="coli"
STRAIN="example_strain"

# Compute settings.
THREADS="4"
# SPAdes expects memory in GB.
SPADES_MEMORY="8"

